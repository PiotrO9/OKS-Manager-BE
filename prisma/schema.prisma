generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // url removed: connection config should be provided via prisma.config.ts or PrismaClient constructor
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}
