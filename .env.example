# Przykładowe zmienne środowiskowe
# Skopiuj ten plik do .env i uzupełnij wartości przed uruchomieniem aplikacji
# NIE commituj prawdziwych sekretów do repozytorium

# PostgreSQL używany przez Prisma (Supabase)
# Format: postgresql://<user>:<pass>@<host>:<port>/<database>?sslmode=require
DATABASE_URL=

# Supabase - dane projektu i klucze
# SUPABASE_URL: Project URL (Settings → API → Project URL)
SUPABASE_URL=
# Klucz service_role (tylko server-side, pełne uprawnienia)
SUPABASE_SERVICE_ROLE_KEY=
# Klucz anon (tylko do użytku client-side jeśli potrzebny)
SUPABASE_ANON_KEY=

# Port serwera (domyślnie 3001)
PORT=3001

# Środowisko (development | production | test)
NODE_ENV=development

# Klucz tajny dla JWT tokenu
SUPABASE_JWT_SECRET=